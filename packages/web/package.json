{
    "name": "@aria51/web",
    "version": "0.1.0",
    "description": "Web UI for accessibility scanning",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/justinirizarry/aria-51.git",
        "directory": "packages/web"
    },
    "publishConfig": {
        "access": "public"
    },
    "type": "module",
    "scripts": {
        "dev": "tsx src/server.ts",
        "build": "rm -rf dist && tsc && cp -r src/public dist/public",
        "start": "node dist/server.js"
    },
    "dependencies": {
        "@aria51/core": "workspace:*",
        "@aria51/components": "workspace:*",
        "@aria51/ai-auditor": "workspace:*",
        "@aria51/agent": "workspace:*",
        "@hono/node-server": "^1.13.0",
        "hono": "^4.7.0"
    },
    "devDependencies": {
        "@types/node": "^20.10.0",
        "tsx": "^4.19.0",
        "typescript": "^5.3.0"
    }
}
